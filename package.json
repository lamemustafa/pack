{
  "name": "@complyeaze/pack",
  "version": "0.3.2",
  "private": true,
  "description": "ComplyEaze Pack: local-first GST filed-return downloader for GSTR-3B PDFs and GSTR-1 PDF/Excel files.",
  "type": "module",
  "homepage": "https://github.com/lamemustafa/pack#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/lamemustafa/pack.git"
  },
  "bugs": {
    "url": "https://github.com/lamemustafa/pack/issues"
  },
  "author": "ComplyEaze <contact@complyeaze.com>",
  "license": "Apache-2.0",
  "packageManager": "pnpm@11.1.2",
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "dev": "wxt",
    "workflow:preflight": "node scripts/check-pack-workflow-preflight.mjs",
    "dev:firefox": "wxt --browser firefox",
    "build": "wxt build",
    "build:firefox": "wxt build --browser firefox",
    "zip": "wxt zip",
    "wxt:prepare": "wxt prepare",
    "compile": "tsc --noEmit",
    "lint": "eslint . --max-warnings 0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "audit:high": "node scripts/run-dependency-audit.mjs",
    "verify:package": "node scripts/verify-extension-package.mjs .output/chrome-mv3",
    "verify:browser": "node scripts/verify-extension-browser.mjs .output/chrome-mv3",
    "verify:zip": "node scripts/verify-extension-zip.mjs",
    "release:provenance": "node scripts/write-release-provenance.mjs",
    "release:verify-assets": "node scripts/verify-github-release-assets.mjs",
    "release:chrome-web-store": "node scripts/publish-chrome-web-store.mjs",
    "release:chrome-web-store-status": "node scripts/check-chrome-web-store-status.mjs",
    "store:assets": "node scripts/export-chrome-web-store-assets.mjs",
    "release:check-pr-title": "node scripts/check-conventional-pr-title.mjs",
    "verify:clean": "node scripts/assert-clean-worktree.mjs",
    "review:gate": "node scripts/check-pr-review-gate.mjs",
    "validate:evidence": "node scripts/validate-live-run-evidence.mjs",
    "evidence:template": "node scripts/create-live-run-evidence-template.mjs",
    "verify:local": "pnpm install --frozen-lockfile && node scripts/run-dependency-audit.mjs && wxt prepare && prettier --check . && eslint . --max-warnings 0 && tsc --noEmit && vitest run && wxt build && node scripts/verify-extension-package.mjs .output/chrome-mv3 && git diff --check",
    "verify": "pnpm verify:local",
    "verify:release": "pnpm verify:local && pnpm verify:clean && wxt zip && node scripts/verify-extension-zip.mjs",
    "verify:pr": "pnpm workflow:preflight && pnpm review:gate -- --strict-head-review --required-review-author chatgpt-codex-connector --wait-head-review-ms 180000 --poll-interval-ms 10000"
  },
  "dependencies": {
    "@wxt-dev/module-react": "^1.1.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "1.55.1",
    "@types/chrome": "^0.0.320",
    "@types/node": "^22.13.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@typescript-eslint/eslint-plugin": "^8.35.0",
    "@typescript-eslint/parser": "^8.35.0",
    "eslint": "^9.29.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react": "^7.37.4",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.7.0",
    "jsdom": "^29.0.0",
    "prettier": "^3.5.3",
    "release-please": "17.10.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.35.0",
    "vitest": "^4.1.9",
    "wxt": "^0.20.27"
  }
}

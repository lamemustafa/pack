    "generatorVersion": "1.0.0"
  },
  "policy": {
    "dataModel": {
      "sensitivity": ["public", "internal", "confidential", "restricted"],
      "data_tags": [
        "personal",
        "regulated_compliance",
        "credential",
        "session_auth",
        "client_data",
        "source_code",
        "local_environment"
      ],
      "provenance": ["real", "synthetic"],
      "lifetime": ["ephemeral", "session", "persistable"],
      "sanitization": ["raw", "tokenized", "redacted", "aggregated"]
    },
    "redaction": {
      "patterns": [
        {
          "id": "gstin",
          "label": "<GSTIN>",
          "pattern": "\\b\\d{2}[A-Z]{5}\\d{4}[A-Z][1-9A-Z]Z[0-9A-Z]\\b"
        },
        { "id": "pan", "label": "<PAN>", "pattern": "\\b[A-Z]{5}\\d{4}[A-Z]\\b" },
        {
          "id": "openai-secret",
          "label": "<SECRET>",
          "pattern": "\\bsk-(?:proj-)?[A-Za-z0-9_-]+\\b"
        },
        {
          "id": "cookie-header",
          "label": "<SECRET>",
          "pattern": "\\b(cookie|authorization)\\s*[:=]\\s*[^\\s;]+"
        },
        { "id": "home-path", "label": "<HOME>", "pattern": "/Users/[^\\s\"']+" },
        {
          "id": "gst-url",
          "label": "<GST_PORTAL_URL>",
          "pattern": "https://(?:www|services|return)\\.gst\\.gov\\.in/[^\\s\"']*"
        }
      ]
    }
  }
}
